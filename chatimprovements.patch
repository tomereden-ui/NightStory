       body: JSON.stringify({ messages: [], childProfile: activeChild }),
+      signal: ctrl.signal,
     })
       .then(async (r) => {
         const data: ChatResponse = await r.json();
@@ -144,12 +156,15 @@ export default function LunaChatPanel({
